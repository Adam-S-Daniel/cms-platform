---
# Custom site-wide Atom feed (REPLACES jekyll-feed's /feed.xml so we can
# filter e2e/test-fixture posts via the shared `feed_exclude` marker that
# theme/lib/cms-platform-theme/exclude_e2e_posts.rb stamps). jekyll-feed
# skips a path that already exists in the source tree, so this file wins
# at /feed.xml. Mirrors jekyll-feed's Atom shape. Site-owned (lives in the
# consuming site, not the theme) — this is the minimal faithful copy a
# real site ships.
layout: null
sitemap: false
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom"{% if site.lang %} xml:lang="{{ site.lang }}"{% endif %}>
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <link href="{{ page.url | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/' | absolute_url }}" rel="alternate" type="text/html"{% if site.lang %} hreflang="{{ site.lang }}"{% endif %} />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ page.url | absolute_url | xml_escape }}</id>
  {% assign feed_title = site.title | default: site.name %}
  {% if feed_title %}
  <title type="html">{{ feed_title | smartify | xml_escape }}</title>
  {% endif %}
  {% if site.description %}
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  {% endif %}
  {% if site.author %}
  <author>
    <name>{{ site.author.name | default: site.author | xml_escape }}</name>
  </author>
  {% endif %}
  {%- comment -%}
    Exclude e2e / test-fixture posts via the shared `feed_exclude` marker
    (stamped by exclude_e2e_posts.rb). Jekyll already drops
    `published: false` posts from `site.posts`.
  {%- endcomment -%}
  {% assign posts = site.posts | where_exp: "post", "post.feed_exclude != true" | sort: "date" | reverse %}
  {% for post in posts limit: 10 %}
  <entry>
    {% assign post_title = post.title | smartify | strip_html | normalize_whitespace | xml_escape %}
    <title type="html">{{ post_title }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post_title }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated>
    <id>{{ post.id | absolute_url | xml_escape }}</id>
    <content type="html" xml:base="{{ post.url | absolute_url | xml_escape }}"><![CDATA[{{ post.content | strip }}]]></content>
    <author><name>{{ site.author.name | default: site.author | default: "" | xml_escape }}</name></author>
  </entry>
  {% endfor %}
</feed>
