# Per-site deploy parameters for the infrastructure/ and oauth-proxy/ stacks,
# AND the single source the repo-variable setter derives from. Copy to
# site-params.env, fill in, then before running any deploy.sh:
#   set -a; source infrastructure/site-params.env; set +a
# The scaffolder (scaffold/) generates this file for a new site.
#
# scripts/set-repo-variables.sh reads APEX_DOMAIN (+ the optional knobs below)
# from here and sets the consumer's GitHub Actions *repository variables*
# (CMS_APEX, CMS_PROD_URL, PREVIEW_BUCKET, AWS_REGION) the reusable workflows
# read via vars.* — so those values are never typed twice.

# ── Required ────────────────────────────────────────────────────────────────
export GITHUB_REPO="example.com"        # owner is GITHUB_ORG below
export APEX_DOMAIN="example.com"         # production apex (no scheme)

# ── OAuth proxy (oauth-proxy/deploy.sh) ──────────────────────────────────────
export GITHUB_CLIENT_ID="xxxxxxxxxxxxxxxx"
export GITHUB_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
export ALLOWED_ORIGINS="https://example.com"
export STACK_NAME="example-com-oauth-proxy"   # oauth-proxy stack/function name

# ── Optional (sensible defaults derive from APEX_DOMAIN) ─────────────────────
# export GITHUB_ORG="Adam-S-Daniel"
# export RESOURCE_PREFIX="example-com"          # apex with dots->hyphens
# export AWS_REGION="us-east-1"
# export HOSTED_ZONE_ID="ZXXXXXXXXXXXXX"         # auto-detected from Route53 if unset
# export PROD_PLAYGROUND_MODE="true"             # opt-in: lets the prod-mutate loop
#                                                #  actually create+delete a live canary.
#                                                #  Leave UNSET on a real prod site
#                                                #  (loop stays report-only); set "true"
#                                                #  only on a throwaway sandbox.
